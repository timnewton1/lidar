#!/usr/bin/env bash
# `lidar queue` — launch multiple runs sequentially, gating each launch on
# available RAM so concurrent jobs don't exceed the machine's memory budget.
#
# Usage:
#   lidar queue [run-flags] <tile-list> [<tile-list>...]
#
# Positional args are tile lists (local files or https:// URLs). All flag args
# are passed through verbatim to each `lidar run` invocation, so every job in
# the queue runs with the same options.
#
# Before launching each job, waits until MemAvailable >= GDAL_CACHEMAX_MB
# (set in lib/common.sh from MemTotal/4, or overridden by env). This keeps
# concurrent job count naturally bounded by RAM without a fixed limit.
#
# Options:
#   --gis-dir PATH   override GIS_DIR (forwarded to each lidar run)
#   -h, --help       show this help

source "${LIDAR_HOME}/lib/strict.sh"

usage() { sed -n '3,17p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'; exit "${1:-1}"; }

TARGETS=()
PASS_ARGS=()
GIS_DIR_OVERRIDE=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --gis-dir)  GIS_DIR_OVERRIDE="$2"; PASS_ARGS+=("$1" "$2"); shift 2 ;;
    -h|--help)  usage 0 ;;
    -*)         PASS_ARGS+=("$1"); shift ;;
    *)          TARGETS+=("$1"); shift ;;
  esac
done

[[ ${#TARGETS[@]} -eq 0 ]] && usage 2

[[ -n "${GIS_DIR_OVERRIDE}" ]] && export GIS_DIR="${GIS_DIR_OVERRIDE}"
source "${LIDAR_HOME}/lib/common.sh"

# GDAL_CACHEMAX_MB is now set. Use it as the MemAvailable gate: don't launch
# the next job until the system has at least that much free, so no job starts
# into a memory hole. The last job in a saturated batch may get slightly less
# than its alloc — that's acceptable.
wait_for_headroom() {
  local need_kb=$(( GDAL_CACHEMAX_MB * 1024 ))
  local avail_kb
  while true; do
    avail_kb=$(awk '/MemAvailable/ {print $2}' /proc/meminfo)
    (( avail_kb >= need_kb )) && return 0
    sleep 5
  done
}

total=${#TARGETS[@]}
idx=0
for target in "${TARGETS[@]}"; do
  idx=$(( idx + 1 ))
  echo "[${idx}/${total}] Waiting for ${GDAL_CACHEMAX_MB} MB headroom..."
  wait_for_headroom
  echo "[${idx}/${total}] Launching: ${target}"
  "${LIDAR_HOME}/libexec/lidar-run" --background "${PASS_ARGS[@]+"${PASS_ARGS[@]}"}" "${target}"
done

echo "All ${total} job(s) queued."
